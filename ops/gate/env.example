# Explicit default bind (same as code default)
UBL_GATE_BIND=0.0.0.0:4000
# Optional data directory override
UBL_DATA_DIR=./data

# Durable store
UBL_STORE_BACKEND=memory
# UBL_STORE_DSN=file:/var/lib/ubl-core/ubl_store.db?mode=rwc&_journal_mode=WAL
# UBL_IDEMPOTENCY_DSN=file:/var/lib/ubl-core/ubl_store.db?mode=rwc&_journal_mode=WAL
# UBL_OUTBOX_DSN=file:/var/lib/ubl-core/ubl_store.db?mode=rwc&_journal_mode=WAL

# Outbox
UBL_OUTBOX_WORKERS=1
# UBL_OUTBOX_ENDPOINT=https://example.internal/outbox

# Eventstore
## default true; descomente para desabilitar
# UBL_EVENTSTORE_ENABLED=false
UBL_EVENTSTORE_PATH=./data/events
